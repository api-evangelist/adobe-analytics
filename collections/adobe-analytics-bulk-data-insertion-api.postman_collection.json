  "info": {
    "_postman_id": "bc703cf1-2b30-4cbf-9748-df50c9147744",
    "name": "Adobe Analytics Bulk Data Insertion API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Bulk Data Insertion API (BDIA) lets you upload server-side call data in batches of gzip-compressed CSV files. Each file contains one event per row and must conform to the BDIA file format specification. This API is the recommended successor to the single-event Data Insertion API for high-volume server-side data collection.\n\nContact Support:\n Name: Adobe Analytics Support",
      "type": "text/plain"
    }
  }
