          "id": "ad918706-5676-4cbb-b324-d39ff3236168",
          "name": "Adobe Analytics Validate a Batch Events File",
          "request": {
            "name": "Adobe Analytics Validate a Batch Events File",
            "description": {
              "content": "Synchronously validates a gzip-compressed CSV events file without ingesting the data. Returns an immediate response indicating whether the file passes format validation, along with detailed error messages for any rows that fail validation. Use this endpoint to test files before uploading to the events endpoint.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "events",
                "validate"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "(Required) The visitor group ID. All files for the same visitors must share the same visitor group ID to ensure correct visitor stitching.",
                "key": "x-adobe-vgid",
                "value": "<string>"
              },
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              },
              {
                "key": "Accept",
                "value": "application/json"
