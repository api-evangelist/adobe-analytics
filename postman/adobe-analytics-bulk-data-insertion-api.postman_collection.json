                    "key": "Authorization",
                    "value": "Bearer <token>"
                  }
                ],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "description": "(Required) Gzip-compressed CSV file containing event data",
                      "key": "file",
                      "type": "file"
                    }
                  ]
                },
                "url": {
                  "raw": "{{baseUrl}}/events",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "events"
                  ]
                }
