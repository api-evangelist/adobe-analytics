  "info": {
    "_postman_id": "e93a6116-53a7-4a37-9106-1b53abfbc45e",
    "name": "Adobe Analytics Bulk Data Insertion API",
    "description": "The Bulk Data Insertion API (BDIA) lets you upload server-side call data in batches of gzip-compressed CSV files. Each file contains one event per row and must conform to the BDIA file format specification. This API is the recommended successor to the single-event Data Insertion API for high-volume server-side data collection.\n\nContact Support:\n Name: Adobe Analytics Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T15:02:36.000Z",
    "updatedAt": "2026-06-05T15:02:36.000Z",
    "lastUpdatedBy": "35240",
