              "id": "464035f2-a199-4eb3-a1a1-342f12c76f98",
              "protocolProfileBehavior": {
                "disableBodyPruning": true
              },
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/:rsid/serverCallEstimate?dateRangeStart=<date>&dateRangeEnd=<date>",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    ":rsid",
                    "serverCallEstimate"
                  ],
                  "query": [
                    {
                      "description": "(Required) Start of the date range for the repair in ISO 8601 format (YYYY-MM-DD)",
                      "key": "dateRangeStart",
                      "value": "<date>"
                    },
                    {
                      "description": "(Required) End of the date range for the repair (inclusive) in ISO 8601 format (YYYY-MM-DD)",
                      "key": "dateRangeEnd",
                      "value": "<date>"
                    }
                  ],
                  "variable": [
                    {
                      "id": "33af4337-ccad-413c-9834-69f4a941f4fc",
                      "key": "rsid",
                      "value": "<string>",
                      "description": "(Required) The report suite ID"
                    }
                  ]
                },
                "description": "Calculates the number of data rows that would be scanned for a repair job given the specified report suite and date range. This estimate is required before creating a repair job and returns a validationToken that must be passed to the job creation endpoint. The count determines the cost of the repair."
