{
  "type": "object",
  "description": "The action to take on a specific variable",
  "properties": {
    "action": {
      "type": "string",
      "description": "The repair action to perform",
      "example": "delete",
      "enum": [
        "delete",
        "set"
      ]
    },
    "setValue": {
      "type": "string",
      "description": "The value to set the variable to (required when action is 'set')",
      "example": "example_value"
    },
    "filter": {
      "type": "object",
      "description": "Optional filter to limit which rows are affected by the repair",
      "properties": {
        "condition": {
          "type": "string",
          "description": "The filter condition type",
          "example": "contains",
          "enum": [
            "contains",
            "streq",
            "startswith"
          ]
        },
        "matchValue": {
          "type": "string",
          "description": "The value to match against for filtering",
          "example": "example_value"
        }
      }
    }
  },
  "required": [
    "action"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RepairAction"
}